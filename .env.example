# Copy to .env and replace placeholders (never commit .env).
OPENAI_API_KEY=your-openai-api-key-here

# Google Sign-In (OAuth 2.0 Web client). Same client id as REACT_APP_GOOGLE_CLIENT_ID in frontend/.env
# GOOGLE_CLIENT_ID=123456789-xxxx.apps.googleusercontent.com

# Optional: persist learner memory in PostgreSQL (matches docker-compose.yml defaults).
# Leave unset to use the in-memory store only.
# DATABASE_URL=postgresql://tutor:tutor@localhost:5432/tutor
OPENAI_CHAT_MODEL=gpt-5.4-mini-2026-03-17
# Faster / cheaper model for exercise generation only (defaults to gpt-4o-mini if unset).
# OPENAI_PRACTICE_MODEL=gpt-4o-mini

# Optional overrides:
# OPENAI_API_KEY_PLACEHOLDER=<your-openai-api-key>
# OPENAI_API_KEY_ENV=OPENAI_API_KEY
# OPENAI_CHAT_MODEL_ENV=OPENAI_CHAT_MODEL
